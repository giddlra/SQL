--For this project, I downloaded Spotify data from Kaggle.
--Then I created a table to insert Spotify data into.
--Finally, I performed an analysis on the data using SQL. 


--Creating the table: 
CREATE TABLE BIT_DB.Spotifydata (
id integer PRIMARY KEY,
artist_name varchar NOT NULL,
track_name varchar NOT NULL,
track_id varchar NOT NULL,
popularity integer NOT NULL,
danceability decimal(4,3) NOT NULL,
energy decimal(4,3) NOT NULL,
key integer NOT NULL,
loudness decimal(5,3) NOT NULL,
mode integer NOT NULL,
speechiness decimal(5,4) NOT NULL,
acousticness decimal(6,5) NOT NULL,
instrumentalness text NOT NULL,
liveness decimal(5,4) NOT NULL,
valence decimal(4,3) NOT NULL,
tempo decimal(6,3) NOT NULL,
duration_ms integer NOT NULL,
time_signature integer NOT NULL 
)

--Then I inserted the Spotify Data .csv into the table.

--Next, I explored the data using the following queries. 

--First, I looked for the top 5 artists in this list based on popularity
SELECT artist_name, popularity
FROM Spotifydata
ORDER BY 2 desc
LIMIT 5;

--Then, I listed the artists that had more than 1 song on the list and sorted by the count of songs
SELECT artist_name, COUNT(artist_name) as num_songs
FROM Spotifydata
GROUP BY 1
HAVING num_songs >= 2
ORDER BY num_songs desc, 1;

--I then looked for the average tempo and danceability for songs with a popularity rating of 90 or higher.
--This could help artists formulate songs in a popular tempo and using dance-inducing rhythm to create a hit.
SELECT AVG(tempo), AVG(danceability)
FROM Spotifydata
WHERE popularity >= 90;
